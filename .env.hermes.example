# ─── Hermes Agent Integration ─────────────────────────────────────────────────
# Copy these into your .env file and fill in real values before running
# docker-compose up hermes-bridge hermes-router hermes-skills

# Hermes Agent Cloud API credentials
HERMES_AGENT_URL=https://api.hermes-agent.com
HERMES_API_KEY=hms_your_api_key_here

# Platform internal HMAC secret (must match PLATFORM_HMAC_SECRET in .env)
PLATFORM_HMAC_SECRET=change_me_to_a_32_char_random_string

# Platform API key for hermes-skills to call back to the platform
PLATFORM_API_KEY=your_platform_internal_api_key

# SMTP for supplier emails (hermes-skills)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# OpenAI for LLM-powered PO generation (hermes-skills)
OPENAI_API_KEY=sk-your_openai_key

# TigerBeetle ledger address (for hermes-router ledger events)
TIGERBEETLE_ADDRESS=127.0.0.1:3000

